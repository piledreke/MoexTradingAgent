DUCKDB_PATH=./data/analyst.duckdb
PARQUET_COLD_DIR=./data/cold

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Scheduler
ENABLE_COLLECTORS=true
WATCHLIST=SBER,GAZP,LKOH,GMKN,ROSN,YNDX,VTBR,TATN,MGNT,MTSS,ALRS,CHMF,NVTK,PLZL,POLY,SNGS,AFLT,MOEX,OZON,FIVE