############################
# MOEX / ALGOPACK
############################
# Required for ALGOPACK endpoints (Bearer token).
# Get one in https://data.moex.com/personal-account
# The agent accepts any of: MOEX_API_KEY, MOEX_ALGOPACK_TOKEN, MOEX_TOKEN.
MOEX_API_KEY=
MOEX_ALGOPACK_TOKEN=
MOEX_BASE_URL=https://apim.moex.com/iss
MOEX_PUBLIC_BASE_URL=https://iss.moex.com/iss
MOEX_REQUEST_TIMEOUT=10
MOEX_MAX_RETRIES=4

############################
# Polza AI (LLM advisor)
############################
# Without this token the agent works in deterministic-only mode.
# Accepts POLZA_AI_API_KEY or POLZA_API_KEY.
POLZA_AI_API_KEY=
POLZA_BASE_URL=https://polza.ai/api/v1
# Accepts POLZA_MODEL or LLM_MODEL.
POLZA_MODEL=openai/gpt-4o
POLZA_TIMEOUT=20
ENABLE_LLM=true

############################
# Arenago (read-only)
############################
# If provided, agent reads positions/trades/bots for portfolio-aware advice.
# It will NEVER call /api/submit_order.
# Accepts ARENAGO_TOKEN or API_BEARER_TOKEN.
ARENAGO_TOKEN=
ARENAGO_BASE_URL=https://arenago.ru
ARENAGO_TIMEOUT=10
# Your bot/portfolio name on arenago.ru (used as the portfolio path parameter
# for /api/positions/<name> and /api/trades/<name>).
BOT_NAME=

############################
# Storage & runtime
############################
DB_PATH=/app/data/tech_agent.sqlite3
LOG_LEVEL=INFO
LOG_JSON=true
RAW_CACHE_RETENTION_DAYS=7

############################
# HTTP API
############################
ENABLE_HTTP=true
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

############################
# Universe & strategy
############################
# Accepts UNIVERSE or WATCHLIST.
UNIVERSE=LKOH,SBER,ROSN,GAZP,VTBR,YDEX,PLZL,T,NVTK,X5,GMKN,MGNT,ALRS,AFLT,CHMF,NLMK,MOEX,SNGSP,MTSS,PIKK
STRATEGY_VERSION=det-1.0

BACKFILL_DAYS=30
POLL_INTERVAL_SECONDS=60
SUPER_CANDLE_INTERVAL_SECONDS=300
HI2_HOUR_MSK=18
HI2_MINUTE_MSK=45

############################
# Risk limits (competition defaults)
############################
INITIAL_CAPITAL_RUB=1000000
DAILY_TRADE_LIMIT=200
MAX_POSITION_PCT=0.10
MAX_SINGLE_ORDER_PCT=0.05
MAX_PORTFOLIO_EXPOSURE_PCT=0.95
RESERVE_CASH_PCT=0.05
MIN_ORDER_CASH_RUB=5000

############################
# Decision thresholds
############################
BUY_SCORE_THRESHOLD=70
MIN_CONFIDENCE_BUY=0.55
HOLD_SCORE_THRESHOLD=45

# Hard veto thresholds
MAX_SPREAD_BBO_BPS=80
MAX_SPREAD_1MIO_BPS=200
MAX_STALE_SECONDS=900
MIN_LIQUIDITY_VAL_B=50000
